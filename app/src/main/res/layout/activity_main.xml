<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- Overlay для лиц -->
    <com.printer.rasp.FaceOverlayView
        android:id="@+id/faceOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Верхняя панель статуса -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/black_80"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статус: ГОТОВ"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:gravity="center"
            android:background="@color/gray"/>

        <TextView
            android:id="@+id/tvMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Режим: Ожидание"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvModelInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:padding="8dp"
            android:background="@color/black_50"/>

        <TextView
            android:id="@+id/tvServerIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/white"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 FPS"
            android:textColor="@color/green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- КНОПКА МЕНЮ -->
    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_manage"
        android:backgroundTint="@color/purple"
        android:background="@drawable/circle_button"
        android:padding="16dp"
        android:elevation="8dp"/>

    <!-- ПАНЕЛЬ УПРАВЛЕНИЯ -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp"
        android:layout_marginEnd="72dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/black_90"
        android:elevation="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="УПРАВЛЕНИЕ"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:background="@color/purple_50"/>

        <!-- Кнопка сервера -->
        <Button
            android:id="@+id/btnStartServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Запустить сервер"
            android:textColor="@color/white"
            android:backgroundTint="@color/purple"
            android:layout_marginTop="8dp"/>

        <!-- Кнопка переключения камеры -->
        <Button
            android:id="@+id/btnSwitchCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Переключить камеру"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white_30"
            android:layout_marginVertical="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ДООБУЧЕНИЕ"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите пользователя:"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <Spinner
            android:id="@+id/spinnerUsers"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_background"
            android:popupBackground="@color/black_90"
            android:dropDownVerticalOffset="4dp"
            android:gravity="center_vertical|start"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginTop="4dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Или введите новое имя"
            android:textColorHint="@color/white_70"
            android:textColor="@color/white"
            android:padding="12dp"
            android:background="@drawable/edittext_border"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnRetrain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 ДООБУЧИТЬ"
            android:textColor="@color/white"
            android:backgroundTint="@color/green"
            android:layout_marginTop="8dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:progressTint="@color/green"/>

        <TextView
            android:id="@+id/tvSamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Образцов: 0/12"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white_30"
            android:layout_marginVertical="12dp"/>

        <Button
            android:id="@+id/btnRecognize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 РАСПОЗНАТЬ"
            android:textColor="@color/white"
            android:backgroundTint="@color/orange"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹️ СТОП"
            android:textColor="@color/white"
            android:backgroundTint="@color/red"
            android:layout_marginTop="8dp"
            android:enabled="false"/>

    </LinearLayout>

</RelativeLayout>